[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 = "res://addons/calypso/debug/libcalypso.so"
linux.release.x86_64 = "res://addons/calypso/release/libcalypso.so"
windows.debug.x86_64 = "res://addons/calypso/debug/calypso.dll"
windows.release.x86_64 = "res://addons/calypso/release/calypso.dll"
macos.debug = "res://addons/calypso/debug/libcalypso.dylib"
macos.release = "res://addons/calypso/release/libcalypso.dylib"
macos.debug.arm64 = "res://addons/calypso/debug/libcalypso.dylib"
macos.release.arm64 = "res://addons/calypso/release/libcalypso.dylib"
